@model WebBanHang.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink:     #1a1a2e;
        --surface: #f8f5f0;
        --card:    #ffffff;
        --gold:    #c9a84c;
        --gold-lt: #fdf6e3;
        --muted:   #7a7a8c;
        --border:  #e4ddd4;
        --radius:  12px;
        --shadow:  0 4px 24px rgba(26,26,46,.08);
    }

    body { background: var(--surface); font-family: 'DM Sans', sans-serif; color: var(--ink); }

    .detail-wrapper {
        max-width: 860px;
        margin: 2.5rem auto 4rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .82rem;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: color .15s;
    }
    .back-link:hover { color: var(--gold); }

    /* ── Layout ── */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
    }
    @@media (max-width: 600px) {
        .detail-grid { grid-template-columns: 1fr; }
    }

    /* ── Gallery ── */
    .gallery-main {
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        background: #f0ebe4;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .gallery-main img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .gallery-main .no-img {
        font-size: 4rem;
        color: #c5bdb4;
    }
    .gallery-thumbs {
        display: flex;
        gap: .6rem;
        margin-top: .75rem;
        flex-wrap: wrap;
    }
    .gallery-thumbs img {
        width: 64px;
        height: 64px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid var(--border);
        cursor: pointer;
        transition: border-color .15s, transform .15s;
    }
    .gallery-thumbs img:hover {
        border-color: var(--gold);
        transform: scale(1.05);
    }

    /* ── Info panel ── */
    .info-panel {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }
    .product-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--ink);
        line-height: 1.25;
    }
    .product-price {
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold);
        letter-spacing: -.02em;
    }

    .info-card {
        background: var(--card);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
    }
    .info-card h5 {
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .6rem;
    }
    .info-card p {
        font-size: .92rem;
        line-height: 1.65;
        color: #4a4a5a;
        margin: 0;
    }

    /* ── Action buttons ── */
    .action-row {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }
    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--ink);
        color: #fff;
        padding: .65rem 1.5rem;
        border-radius: 50px;
        font-size: .875rem;
        font-weight: 500;
        text-decoration: none;
        transition: background .2s, transform .15s;
    }
    .btn-edit:hover { background: var(--gold); color: var(--ink); transform: translateY(-1px); }

    .btn-cart {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--gold); /* Dùng màu vàng làm chủ đạo */
        color: #fff;
        padding: .65rem 1.5rem;
        border-radius: 50px;
        font-size: .875rem;
        font-weight: 700;
        text-decoration: none;
        transition: background .2s, transform .15s;
    }

        .btn-cart:hover {
            background: var(--ink);
            color: #fff;
            transform: translateY(-1px);
        }
    .btn-del {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: transparent;
        color: #c0392b;
        padding: .65rem 1.5rem;
        border-radius: 50px;
        font-size: .875rem;
        font-weight: 500;
        text-decoration: none;
        border: 1.5px solid #f5c6c2;
        transition: background .2s, color .2s;
    }
    .btn-del:hover { background: #fdf0ee; }
</style>

<div class="container">
    <div class="detail-wrapper">
        <a asp-action="Index" class="back-link">← Quay lại danh sách</a>

        <div class="detail-grid">
            <!-- Gallery -->
            <div>
                <div class="gallery-main">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="no-img">🛍️</div>
                    }
                </div>

                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <div class="gallery-thumbs">
                        @foreach (var url in Model.ImageUrls)
                        {
                            <img src="@url" alt="Ảnh phụ" />
                        }
                    </div>
                }
            </div>

            <!-- Info -->
            <div class="info-panel">
                <h1 class="product-name">@Model.Name</h1>
                <div class="product-price">@Model.Price.ToString("N0") ₫</div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="info-card">
                        <h5>Mô tả sản phẩm</h5>
                        <p>@Model.Description</p>
                    </div>
                }

                <div class="action-row">
                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn-cart">🛒 Thêm vào giỏ</a>

                    <a asp-action="Update" asp-route-id="@Model.Id" class="btn-edit">✏️ Chỉnh sửa</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-del">🗑 Xóa</a>
                </div>
            </div>
        </div>
    </div>
</div>
