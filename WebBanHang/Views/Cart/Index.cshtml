@model IEnumerable<WebBanHang.Models.CartItem> // Giả định bạn có một lớp CartItem chứa Product và Quantity

@{
    ViewData["Title"] = "Giỏ Hàng";
}

<style>
    /* ── Header ── */
    .cart-header {
        padding: 2.5rem 0 1.75rem;
        border-bottom: 1px solid #e4ddd4;
        margin-bottom: 2.5rem;
    }

    .cart-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
    }

        .cart-title span {
            color: var(--gold);
        }

    /* ── Layout chính ── */
    .cart-container {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 2.5rem;
        align-items: start;
    }

    @@media (max-width: 992px) {
        .cart-container {
            grid-template-columns: 1fr;
        }
    }

    /* ── Danh sách sản phẩm ── */
    .cart-items-list {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #ede8e2;
        box-shadow: 0 4px 24px rgba(26,26,46,.04);
        padding: 1.5rem;
    }

    .cart-item {
        display: flex;
        align-items: center;
        padding: 1.5rem 0;
        border-bottom: 1px solid #f0ebe4;
    }

        .cart-item:last-child {
            border-bottom: none;
            border-bottom-left-radius: 12px;
        }

        .cart-item:first-child {
            padding-top: 0;
        }

    .item-img {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border-radius: 8px;
        background: #f0ebe4;
        margin-right: 1.5rem;
    }

    .item-details {
        flex: 1;
    }

    .item-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--ink);
        text-decoration: none;
        margin-bottom: 0.25rem;
        display: block;
    }

    .item-desc {
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 0;
    }

    .item-price {
        font-weight: 600;
        color: var(--ink);
        margin: 0 2rem;
        font-size: 1.05rem;
    }

    /* Bộ tăng giảm số lượng tinh tế */
    .quantity-control {
        display: flex;
        align-items: center;
        border: 1px solid #e4ddd4;
        border-radius: 50px;
        padding: 2px;
        background: var(--surface);
    }

    .quantity-btn {
        background: none;
        border: none;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ink);
        font-size: 1.1rem;
        cursor: pointer;
        border-radius: 50%;
        transition: background 0.2s;
    }

        .quantity-btn:hover {
            background: #fff;
            color: var(--gold);
        }

    .quantity-input {
        width: 40px;
        text-align: center;
        border: none;
        background: none;
        font-weight: 500;
        color: var(--ink);
    }

    .btn-remove {
        background: none;
        border: none;
        color: var(--danger);
        margin-left: 2rem;
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

        .btn-remove:hover {
            opacity: 1;
        }

    /* ── Tóm tắt đơn hàng ── */
    .summary-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #ede8e2;
        box-shadow: 0 4px 24px rgba(26,26,46,.04);
        padding: 2rem;
    }

    .summary-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--ink);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        font-size: 0.95rem;
        color: var(--muted);
    }

        .summary-row.total {
            border-top: 1px solid #f0ebe4;
            padding-top: 1.25rem;
            margin-top: 1.25rem;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--ink);
        }

            .summary-row.total .total-price {
                color: var(--gold);
            }

    .btn-checkout {
        display: block;
        text-align: center;
        background: var(--ink);
        color: #fff;
        padding: 1rem;
        border-radius: 50px;
        font-weight: 500;
        text-decoration: none;
        margin-top: 2rem;
        transition: background 0.2s, transform 0.15s;
    }

        .btn-checkout:hover {
            background: var(--gold);
            color: var(--ink);
            transform: translateY(-1px);
        }

    .btn-continue {
        display: block;
        text-align: center;
        color: var(--ink);
        text-decoration: none;
        font-size: 0.9rem;
        margin-top: 1rem;
        font-weight: 500;
    }

        .btn-continue:hover {
            color: var(--gold);
        }
</style>

<div class="container">
    <div class="cart-header">
        <h1 class="cart-title">Giỏ hàng <span>Của Bạn</span></h1>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5" style="color: var(--muted)">
            <div style="font-size: 4rem; margin-bottom: 1rem;">🛍️</div>
            <p style="font-size: 1.1rem;">Giỏ hàng của bạn đang trống rỗng.</p>
            <a asp-controller="Product" asp-action="Index" class="btn-checkout d-inline-block px-5 mt-2">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="cart-container">
            <div class="cart-items-list">
                @foreach (var item in Model)
                {
                    <div class="cart-item">
                        <img class="item-img" src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/images/tải xuống.jpg" : item.Product.ImageUrl)" alt="@item.Product.Name" />

                        <div class="item-details">
                            <a asp-controller="Product" asp-action="Display" asp-route-id="@item.Product.Id" class="item-name">@item.Product.Name</a>
                            <p class="item-desc">@item.Product.Description</p>
                        </div>

                        <div class="item-price">
                            @item.Product.Price.ToString("N0") ₫
                        </div>

                        <div class="quantity-control">
                            <button class="quantity-btn" onclick="location.href='@Url.Action("UpdateQuantity", "Cart", new { id = item.Product.Id, quantity = item.Quantity - 1 })'">-</button>
                            <input type="text" class="quantity-input" value="@item.Quantity" readonly />
                            <button class="quantity-btn" onclick="location.href='@Url.Action("UpdateQuantity", "Cart", new { id = item.Product.Id, quantity = item.Quantity + 1 })'">+</button>
                        </div>

                        <button class="btn-remove" onclick="location.href='@Url.Action("RemoveFromCart", "Cart", new { id = item.Product.Id })'">
                            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                }
            </div>

            <div class="summary-card">
                <h3 class="summary-title">Tóm tắt đơn hàng</h3>
                <div class="summary-row">
                    <span>Tạm tính</span>
                    <span>@Model.Sum(x => x.Product.Price * x.Quantity).ToString("N0") ₫</span>
                </div>
                <div class="summary-row">
                    <span>Giao hàng</span>
                    <span>Miễn phí</span>
                </div>
                <div class="summary-row total">
                    <span>Tổng cộng</span>
                    <span class="total-price">@Model.Sum(x => x.Product.Price * x.Quantity).ToString("N0") ₫</span>
                </div>

                <a asp-controller="Cart" asp-action="Checkout" class="btn-checkout">Tiến hành thanh toán</a>
                <a asp-controller="Product" asp-action="Index" class="btn-continue">← Tiếp tục mua sản phẩm khác</a>
            </div>
        </div>
    }
</div>