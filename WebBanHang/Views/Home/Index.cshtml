@model IEnumerable<WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Sản Phẩm";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink:     #1a1a2e;
        --surface: #f8f5f0;
        --card:    #ffffff;
        --gold:    #c9a84c;
        --gold-lt: #f0e0b0;
        --muted:   #7a7a8c;
        --danger:  #c0392b;
        --radius:  12px;
        --shadow:  0 4px 24px rgba(26,26,46,.08);
    }

    body { background: var(--surface); font-family: 'DM Sans', sans-serif; color: var(--ink); }

    /* ── Header bar ── */
    .pg-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2.5rem 0 1.75rem;
        border-bottom: 1px solid #e4ddd4;
        margin-bottom: 2rem;
    }
    .pg-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -.02em;
    }
    .pg-title span { color: var(--gold); }

    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: var(--ink);
        color: #fff;
        padding: .65rem 1.4rem;
        border-radius: 50px;
        font-size: .875rem;
        font-weight: 500;
        text-decoration: none;
        transition: background .2s, transform .15s;
        letter-spacing: .02em;
    }
    .btn-add:hover { background: var(--gold); color: var(--ink); transform: translateY(-1px); }
    .btn-add svg { width: 16px; height: 16px; }

    /* ── Grid ── */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1.5rem;
        padding-bottom: 3rem;
    }

    /* ── Card ── */
    .product-card {
        background: var(--card);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform .2s, box-shadow .2s;
        border: 1px solid #ede8e2;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(26,26,46,.13);
    }

    .card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        background: #f0ebe4;
    }
    .card-img-placeholder {
        width: 100%;
        height: 200px;
        background: linear-gradient(135deg, #f0ebe4 0%, #e8dfd4 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c5bdb4;
        font-size: 2.5rem;
    }

    .card-body {
        padding: 1.25rem 1.4rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .card-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--ink);
        margin-bottom: .4rem;
        line-height: 1.3;
    }
    .card-desc {
        font-size: .82rem;
        color: var(--muted);
        line-height: 1.5;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-price {
        margin-top: .9rem;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--gold);
        letter-spacing: -.01em;
    }

    .card-actions {
        display: flex;
        border-top: 1px solid #f0ebe4;
    }
    .card-actions a {
        flex: 1;
        text-align: center;
        padding: .7rem .5rem;
        font-size: .8rem;
        font-weight: 500;
        text-decoration: none;
        transition: background .15s, color .15s;
        letter-spacing: .03em;
        text-transform: uppercase;
    }
    .card-actions a + a { border-left: 1px solid #f0ebe4; }
    .a-view  { color: var(--ink); }
    .a-edit  { color: #2c6fad; }
    .a-del   { color: var(--danger); }
    .card-actions a:hover { background: #faf7f3; }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 5rem 1rem;
        color: var(--muted);
    }
    .empty-state .icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .empty-state p { font-size: 1rem; }
</style>

<div class="container">
    <div class="pg-header">
        <h1 class="pg-title">Danh sách <span>Sản Phẩm</span></h1>
        <a asp-action="Add" class="btn-add">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Thêm sản phẩm
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon">📦</div>
            <p>Chưa có sản phẩm nào. Hãy thêm sản phẩm đầu tiên!</p>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var product in Model)
            {
                <div class="product-card">
                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <img class="card-img" src="@product.ImageUrl" alt="@product.Name" />
                    }
                    else
                    {
                        <div class="card-img-placeholder">🛍️</div>
                    }
                    <div class="card-body">
                        <div class="card-name">@product.Name</div>
                        <div class="card-desc">@product.Description</div>
                        <div class="card-price">@product.Price.ToString("N0") ₫</div>
                    </div>
                    <div class="card-actions">
                        <a class="a-view" asp-action="Display" asp-route-id="@product.Id">Xem</a>
                        <a class="a-edit" asp-action="Update" asp-route-id="@product.Id">Sửa</a>
                        <a class="a-del"  asp-action="Delete"  asp-route-id="@product.Id">Xóa</a>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts { }
